# Dash configuration — copy this file to `.env.local` and fill in your own
# Supabase project's values. "Bring your own Supabase": nothing is hardcoded, so
# these MUST be set for the app to work.
#
#   cp .env.example .env.local
#
# These are read by node (the CLI + dev server) from this file, AND baked into
# the browser bundle at build time via Vite. Set them BEFORE `npm run build`.

# Your project URL, from Supabase → Project Settings → API.
DASH_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# The public anon / publishable key. Safe to ship to the browser — on its own it
# grants no access (the schema's RLS gates everything to allow-listed sign-ins).
DASH_SUPABASE_ANON_KEY=your-anon-public-key

# The service-role key. NODE ONLY — never shipped to the browser. It bypasses
# RLS so the local server can read/write the board. Keep it secret; leave it
# unset if you only run the static, sign-in-gated board.
DASH_SUPABASE_SERVICE_KEY=your-service-role-key

# --- Optional: network exposure (the terminal spawns a real shell) ------------
# By default Dash binds loopback only (127.0.0.1) and the terminal websocket
# accepts loopback origins only. Uncomment to expose it deliberately — only on a
# trusted network.
# DASH_HOST=0.0.0.0
# DASH_ALLOWED_ORIGINS=https://dash.example.com
#
# When bound to a routable host, the terminal handshake ALSO requires a secret
# token — otherwise the Origin check (which only constrains browsers) leaves the
# PTY open to any direct network client. Dash auto-generates one and prints the
# URL to open (…/?token=…) at startup, so you don't need to set this. Pin your
# own to keep a stable URL, or to require a token on loopback too:
# DASH_TERMINAL_TOKEN=your-long-random-secret
